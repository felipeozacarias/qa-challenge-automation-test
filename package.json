{
  "name": "qa-challenge-cypress-cucumber",
  "version": "1.0.0",
  "description": "Desafio técnico QA Sr - Cypress + JavaScript + Cucumber + API",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "test:web": "cypress run --spec \"cypress/e2e/web/**/*.feature\"",
    "test:api": "cypress run --spec \"cypress/e2e/api/**/*.feature\""
  },
  "keywords": [
    "qa",
    "cypress",
    "cucumber",
    "bdd",
    "javascript",
    "automation"
  ],
  "author": "Felipe Zacarias",
  "license": "MIT",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^20.0.5",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.0",
    "cypress": "^13.17.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/step_definitions/**/*.js"
    ],
    "json": {
      "enabled": true,
      "output": "cypress/reports/cucumber-report.json"
    },
    "messages": {
      "enabled": true,
      "output": "cypress/reports/messages.ndjson"
    }
  }
}
